# === RamyPulse — Variables d'environnement ===
# Copier ce fichier: cp .env.example .env
# Puis remplir les valeurs

# Google Gemini (obligatoire pour le SentimentAdapter / LLM arbitrage)
GOOGLE_API_KEY=

# Perplexity (V2, optionnel)
PERPLEXITY_API_KEY=

# YouTube Data API (optionnel)
YOUTUBE_API_KEY=

# Google Maps API (optionnel)
GOOGLE_MAPS_API_KEY=

# Tavily API (optionnel)
TAVILY_API_KEY=

# Apify (optionnel — scrapers Facebook / Google Maps)
APIFY_API_KEY=
