# === RamyPulse — Variables d'environnement ===
# Copier ce fichier : cp .env.example .env
# Puis remplir les valeurs nécessaires

# ---------------------------------------------------------------------------
# LLM & IA — Agents de recommandation et onboarding
# ---------------------------------------------------------------------------

# Google Gemini (obligatoire — agent de recommandation par défaut)
GOOGLE_API_KEY=

# OpenAI (obligatoire pour le Smart Onboarding Wizard — Lot 2)
OPENAI_API_KEY=

# SerpApi (obligatoire pour le Smart Onboarding Wizard — découverte marque)
SERPAPI_API_KEY=

# Anthropic Claude (optionnel — provider alternatif pour les agents)
ANTHROPIC_API_KEY=

# Perplexity (optionnel — provider alternatif)
PERPLEXITY_API_KEY=

# Provider et modèle par défaut de l'agent (optionnel)
# Valeurs : google_gemini | openai | anthropic | ollama_local
AGENT_PROVIDER=
AGENT_MODEL=

# ---------------------------------------------------------------------------
# Collecte de données — APIs externes
# ---------------------------------------------------------------------------

# YouTube Data API (optionnel)
YOUTUBE_API_KEY=

# Google Maps API (optionnel)
GOOGLE_MAPS_API_KEY=

# Tavily API (optionnel — enrichissement web)
TAVILY_API_KEY=

# Apify (optionnel — scrapers Facebook / Instagram / Google Maps — Lot 1)
APIFY_API_KEY=

# ---------------------------------------------------------------------------
# Multi-tenant
# ---------------------------------------------------------------------------

# Client de repli pour l'expo quand aucun tenant actif n'est défini
# Par défaut : ramy-demo
SAFE_EXPO_CLIENT_ID=

# ---------------------------------------------------------------------------
# Notifications e-mail (optionnel)
# ---------------------------------------------------------------------------

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD_REFERENCE=
SMTP_FROM_EMAIL=

# Destinataires des rapports hebdomadaires et alertes
WEEKLY_REPORT_EMAIL_TO=
ALERT_NOTIFICATION_EMAIL_TO=

# ---------------------------------------------------------------------------
# Notifications Slack (optionnel)
# ---------------------------------------------------------------------------

WEEKLY_REPORT_SLACK_WEBHOOK_REFERENCE=
ALERT_NOTIFICATION_SLACK_WEBHOOK_REFERENCE=

# Sévérité minimale pour déclencher une notification d'alerte
# Valeurs : low | medium | high | critical
ALERT_NOTIFICATION_MIN_SEVERITY=high

# ---------------------------------------------------------------------------
# Ollama (optionnel — modèles locaux)
# ---------------------------------------------------------------------------

OLLAMA_BASE_URL=
OLLAMA_MODEL=

# ---------------------------------------------------------------------------
# Runtime (optionnel)
# ---------------------------------------------------------------------------

RAMYPULSE_RUNTIME_MODE=
